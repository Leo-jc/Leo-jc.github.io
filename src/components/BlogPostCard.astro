---
interface Props {
  title: string;
  description: string;
  image?: string;
  link: string;
  tags?: string[];
  pubDate?: Date;
  readingTime?: string;
}

const { title, description, image, link, tags = [], pubDate, readingTime } = Astro.props;
---

<article class="group relative bg-card border border-border rounded-lg overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
  {image && (
    <div class="aspect-video overflow-hidden">
      <img
        src={image}
        alt={title}
        class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}
  
  <div class="p-6">
    <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">
      <a href={link} class="before:content-[''] before:absolute before:inset-0">
        {title}
      </a>
    </h3>
    
    <p class="text-muted-foreground text-sm mb-4 line-clamp-2">
      {description}
    </p>
    
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-2 flex-wrap">
        {tags.slice(0, 3).map((tag) => (
          <span class="px-2 py-1 bg-accent text-accent-foreground text-xs rounded-full">
            {tag}
          </span>
        ))}
      </div>
      
      {(pubDate || readingTime) && (
        <div class="text-xs text-muted-foreground">
          {pubDate && (
            <time dateTime={pubDate.toISOString()}>
              {pubDate.toLocaleDateString('zh-CN', {
                year: 'numeric',
                month: 'short',
                day: 'numeric',
              })}
            </time>
          )}
          {readingTime && pubDate && <span> · </span>}
          {readingTime && <span>{readingTime}</span>}
        </div>
      )}
    </div>
  </div>
</article>
