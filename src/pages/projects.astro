---
import BaseLayout from '@layouts/BaseLayout.astro';
import { PROJECTS } from '@/config';
import ProjectCard from '@components/ProjectCard.astro';
---

<BaseLayout
  title="项目作品 - 我的个人主页"
  description="查看我的个人项目和作品"
>
  <section class="container px-4 md:px-6 py-12 md:py-16">
    <div class="max-w-6xl mx-auto">
      <div class="mb-12 text-center">
        <h1 class="text-4xl font-bold mb-4">项目作品</h1>
        <p class="text-muted-foreground max-w-2xl mx-auto">
          这里展示了我的一些个人项目、开源贡献和实验性作品
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {PROJECTS.map((project) => (
          <ProjectCard
            name={project.name}
            description={project.description}
            image={project.image}
            link={project.link}
            tags={project.tags}
          />
        ))}
      </div>
      
      <!-- More Projects Section -->
      <div class="mt-16 text-center">
        <h2 class="text-2xl font-bold mb-4">查看更多</h2>
        <p class="text-muted-foreground mb-6">
          更多项目请访问我的 GitHub
        </p>
        <a
          href="https://github.com/yourusername"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center px-6 py-3 bg-primary text-primary-foreground font-medium rounded-lg hover:bg-primary/90 transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.24-.726-1.088-3.221 0-6.721 0 0 1.088-.345 3.556 1.328 1.032-.286 2.134-.429 3.236-.43 1.102.001 2.204.144 3.236.43 2.468-1.673 3.556-1.328 3.556-1.328 1.088 3.5 1.088 5.995 1.088 6.721 0 .726-.848 3.221-1.088 3.221.768.84 1.235 1.91 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          访问 GitHub
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
