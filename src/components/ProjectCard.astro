---
interface Props {
  name: string;
  description: string;
  image?: string;
  link: string;
  tags: string[];
}

const { name, description, image, link, tags } = Astro.props;
---

<div class="group relative bg-card border border-border rounded-lg overflow-hidden hover:shadow-lg transition-all duration-300">
  {image && (
    <div class="aspect-video overflow-hidden">
      <img
        src={image}
        alt={name}
        class="object-cover w-full h-full group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
      />
    </div>
  )}
  
  <div class="p-6">
    <h3 class="text-xl font-semibold mb-2">
      <a
        href={link}
        target="_blank"
        rel="noopener noreferrer"
        class="text-primary hover:underline"
      >
        {name}
      </a>
    </h3>
    
    <p class="text-muted-foreground text-sm mb-4">
      {description}
    </p>
    
    <div class="flex flex-wrap gap-2">
      {tags.map((tag) => (
        <span class="px-2 py-1 bg-accent text-accent-foreground text-xs rounded-full">
          {tag}
        </span>
      ))}
    </div>
  </div>
</div>
